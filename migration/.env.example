# Copia este archivo como ".env" y completa con tus datos reales.
# Los encuentras en Supabase: Project Settings -> API

SUPABASE_URL=https://TU-PROYECTO.supabase.co

# ⚠️ Esta es la "service_role key" (NO la "anon key").
# Tiene permisos totales: úsala SOLO aquí, en este script que corres
# tú desde tu PC. Jamás la pegues en el código Angular ni la subas a Git.
SUPABASE_SERVICE_ROLE_KEY=

# Nombre del bucket de Storage donde se guardarán las imágenes
SUPABASE_BUCKET=mangas

# Ruta relativa (desde esta carpeta migration/) a la carpeta /public
# de tu proyecto Angular, donde están las imágenes reales hoy.
PUBLIC_DIR=../OtakuPoint_Ecc/public
